{
  "name": "sov-lint",
  "version": "0.1.0",
  "description": "Linter für digitale Abhängigkeits-Stücklisten im Mittelstand. Validiert CycloneDX-Dateien gegen das dsov-Profil (Jurisdiktion, Daten, Abhängigkeit, Exit). Von Pangea Intelligence.",
  "keywords": [
    "digital-sovereignty",
    "digitale-souveraenitaet",
    "cyclonedx",
    "sbom",
    "saasbom",
    "klumpenrisiko",
    "mittelstand",
    "nis2",
    "supply-chain",
    "validator",
    "linter"
  ],
  "license": "Apache-2.0",
  "author": "Pangea Intelligence <contact@pangea-intelligence.eu> (https://pangea-intelligence.eu)",
  "homepage": "https://github.com/pangea-intelligence/sov-lint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pangea-intelligence/sov-lint.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sov-lint": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "schemas",
    "spec",
    "templates",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
